# Solana wallet private key (base58-encoded) for the deployer/creator
SOLANA_PRIVATE_KEY=

# Solana RPC endpoint (defaults to mainnet-beta)
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# Lit Protocol Ethereum wallet private key (hex, 0x-prefixed) for PKP minting/session auth
ETH_PRIVATE_KEY=

# Lit Protocol Naga network
LIT_NETWORK=naga

# Deployed pool addresses (populated after `create-pools`)
LEAK_POOL_ADDRESS=
DONT_LEAK_POOL_ADDRESS=

# Deployed token mints (populated after `mint-tokens`)
LEAK_MINT=
DONT_LEAK_MINT=

# PKP public key (populated after `encrypt`)
PKP_PUBLIC_KEY=
PKP_TOKEN_ID=

# IPFS/Arweave CID of encrypted payload (populated after `encrypt`)
ENCRYPTED_PAYLOAD_CID=
