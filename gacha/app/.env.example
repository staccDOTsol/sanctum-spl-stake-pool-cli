# Solana RPC endpoint
SOLANA_RPC=https://rpc.shyft.to?api_key=vK9_JUsPkMTJY6fE

# Jupiter API key
JUP_API_KEY=jup_de1fb840095b7fd151cc9b44ef3888434887850fad7b797936c3b5119402ee7f

# Matchmaker keypair — base58 privkey or JSON array
MATCHMAKER_KEYPAIR=

# Matchmaker public key (for user-facing CLI commands)
MATCHMAKER_PUBKEY=

# Minimum SOL roll fee accepted (default 0.003)
MIN_ROLL_FEE_SOL=0.003

# One payment of N× the roll fee buys N swaps — the "10-pull" (default 10)
MAX_ROLLS_PER_PAYMENT=10

# Pity: consecutive losing rolls before the up-only guarantee kicks in
GACHA_PITY_HARD=90
GACHA_PITY_SOFT=74

# Where the provably-fair swap history is persisted
SWAP_HISTORY_PATH=./swap-history.json

# User keypair (for delegate/roll commands)
USER_KEYPAIR=
